{
    "mcpServers": {
      "jeb": {
        "command": "uv",
        "args": [
          "--directory",
          "jebmcp/jeb-mcp/src/jeb_mcp",
          "run",
          "server.py"
        ],
        "timeout": 1800,
        "disabled": false,
        "autoApprove": [
          "check_connection",
          "get_manifest",
          "get_exported_components",
          "get_all_classes",
          "list_dex_strings",
          "export_all_resources",
          "get_apk_all_files",
          "get_apk_file_content",
          "check_java_identifier",
          "get_class_hierarchy",
          "get_class_members",
          "get_method_overrides",
          "list_cross_references",
          "get_smali_code",
          "get_decompiled_code",
          "add_comment",
          "rename_code_item",
          "rename_pseudo_code_variables",
          "search_in_project",
          "perform_security_scan"
        ]
      }
    }
}